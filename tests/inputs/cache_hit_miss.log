	@triton.jit
	def forward_inner(
	    arg_Q, arg_K, arg_V, arg_LSE, arg_KV_NUM_BLKS, arg_KV_IDX, arg_FULL_KV_NUM_BLKS, arg_FULL_KV_IDX, out_ptr0,
	    q, K_block_ptr, V_block_ptr, Q_LEN, KV_LEN,
