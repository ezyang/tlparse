	        base=Q,
	        shape=(Q_LEN, QK_HEAD_DIM),
	        strides=(stride_qm, stride_qk),
	        offsets=(q_start * BLOCK_M, 0),
	        block_shape=(BLOCK_M, QK_HEAD_DIM),
